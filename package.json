{
  "name": "vendlyhub",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.27.0",
  "scripts": {
    "prepare": "husky",
    "dev": "turbo run dev start:dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "dev:web": "pnpm --filter vendlyhub-web dev",
    "dev:backend": "pnpm --filter vendlyhub-backend start:dev",
    "build:web": "pnpm --filter vendlyhub-web build",
    "build:backend": "pnpm --filter vendlyhub-backend build",
    "lint:web": "pnpm --filter vendlyhub-web lint",
    "lint:backend": "pnpm --filter vendlyhub-backend lint",
    "test:backend": "pnpm --filter vendlyhub-backend test"
  },
  "devDependencies": {
    "husky": "9.1.7",
    "turbo": "^2.5.3"
  }
}
